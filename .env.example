# OpenChamber UI password (optional). If set, the web UI requires authentication.
# UI_PASSWORD=your_secure_password_here

# External OpenCode server (optional). If OPENCODE_EXTERNAL=true, OpenChamber
# will connect to an existing OpenCode instance instead of starting its own.
# OPENCODE_EXTERNAL=true
# OPENCODE_HOSTNAME=opencode
# OPENCODE_PORT=4096

# Timezone
TZ=Etc/UTC
